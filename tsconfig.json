{
  "compilerOptions": {
    "target":            "ES2020",
    "module":            "ESNext",
    "moduleResolution":  "bundler",
    "allowJs":           true,
    "checkJs":           true,
    "strict":            true,
    "noEmit":            true,
    "skipLibCheck":      true,
    "lib":               ["ES2020", "DOM", "DOM.Iterable"],
    "baseUrl":           ".",
    "paths": {
      "/js/*": ["src/js/*"],
      "/css/*": ["src/css/*"]
    }
  },
  "include": [
    "src/**/*.js",
    "global.d.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}